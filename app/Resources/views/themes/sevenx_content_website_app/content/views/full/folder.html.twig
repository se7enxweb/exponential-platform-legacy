{#
    "Good Intentions" — Dynamic Folder Content Launcher
    ─────────────────────────────────────────────────────
    A pseudo landing page that dynamically surfaces:
      • All non-empty content type attributes (fully dynamic, zero hard-coded fields)
      • Rich content + location metadata panel
      • System navigation links (content tree, admin, login/logout)
      • Full REST API v2 endpoint index for this content + location
      • Content type schema table (all field definitions, type, required, has value)
      • Ecosystem navigation sidebar card

    Safe API — only core eZ Platform Twig functions used:
      ez_content_name(content)        — rendered display name
      ez_render_field(content, id)    — core field block rendering
      ez_is_field_empty(content, id)  — safe empty check
      content.contentType             — ContentType value object
      content.contentInfo             — ContentInfo value object
      content.versionInfo             — VersionInfo value object
      location.*                      — core Location value object
      path(route, params)             — Symfony route generator
#}

{% extends pagelayout is defined ? pagelayout : "themes/sevenx-content-website-app/pagelayout.html.twig" %}

{% block page_title -%}
{%- set _name = ez_content_name(content) -%}
{%- set _alias = path('ez_urlalias', {locationId: location.id})|trim('/') -%}
{%- set _raw_parts = (_alias and not (_alias starts with 'view/')) ? _alias|split('/') : [] -%}
{%- set _parent_parts = [] -%}
{%- for part in _raw_parts|slice(0, -1) -%}{%- set _parent_parts = _parent_parts|merge([part|replace({'-': ' ', '_': ' '})|title]) -%}{%- endfor -%}
{%- set _path_label = _parent_parts|length > 0 ? (_parent_parts|join(' / ') ~ ' / ' ~ _name) : _name -%}
{{ _path_label }} - Exponential Platform is The Power User's CMS / DXP
{%- endblock %}

{% block content %}

{%- set ct    = content.contentType is defined ? content.contentType : null -%}
{%- set ci    = content.contentInfo is defined ? content.contentInfo : null -%}
{%- set vi    = content.versionInfo is defined ? content.versionInfo : null -%}
{%- set lpath = location.pathString|trim('/') -%}
{%- set skip  = ['name', 'short_name'] -%}

<div style="font-family:system-ui,-apple-system,sans-serif;color:#0f172a;line-height:1.55;min-width:0;">

    {% include '@ezdesign/parts/content_hero.html.twig' with {
        content:  content,
        location: location,
        ct:       ct,
        vi:       vi,
    } only %}


    {# ════════════════════════════════════════════════
       TWO-COLUMN LAYOUT
    ════════════════════════════════════════════════ #}
    <div id="sxa-layout" style="display:grid;grid-template-columns:1fr 272px;gap:24px;align-items:start;">


        {# ┌─────────────────────────────────────────┐
           │  MAIN COLUMN                            │
           └─────────────────────────────────────────┘ #}
        <div style="min-width:0;">

            {# ── Dynamic field cards ── #}
            {% for fieldDef in (ct ? ct.fieldDefinitions : []) %}
                {% if fieldDef.identifier not in skip %}
                    {% if not ez_is_field_empty(content, fieldDef.identifier) %}
                        <div style="margin-bottom:18px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04);">
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;padding:9px 16px;background:#f8fafc;border-bottom:1px solid #f1f5f9;">
                                <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#475569;">
                                    {{ fieldDef.names|first|default(fieldDef.identifier) }}
                                </span>
                                <code style="font-size:10px;font-family:ui-monospace,monospace;color:#94a3b8;background:#eef2f7;padding:1px 7px;border-radius:4px;white-space:nowrap;">{{ fieldDef.fieldTypeIdentifier }}</code>
                            </div>
                            <div style="padding:14px 16px;font-size:14px;color:#334155;line-height:1.7;word-break:break-word;overflow-x:auto;">
                                {{ ez_render_field(content, fieldDef.identifier) }}
                            </div>
                        </div>
                    {% endif %}
                {% endif %}
            {% endfor %}


            {# ── Contents ── #}
            {%- set children = ez_location_children(location, 50) -%}
            <div style="margin-bottom:28px;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:12px;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748b;">Contents</span>
                    <span style="font-size:10px;color:#94a3b8;font-family:ui-monospace,monospace;">{{ children|length }} item{{ children|length != 1 ? 's' : '' }}</span>
                </div>
                {% if children|length == 0 %}
                    <div style="padding:20px;text-align:center;color:#94a3b8;font-size:12px;border:1px dashed #e2e8f0;border-radius:8px;">
                        This folder is empty.
                    </div>
                {% else %}
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">
                        {% for child in children %}
                            {%- set childContent = child.getContent() -%}
                            <a href="{{ path('ez_urlalias', {locationId: child.id}) }}"
                               style="display:flex;flex-direction:column;gap:6px;padding:12px 14px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;text-decoration:none;box-shadow:0 1px 3px rgba(0,0,0,.04);"
                               onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.10)';this.style.borderColor='#bfdbfe'"
                               onmouseout="this.style.boxShadow='0 1px 3px rgba(0,0,0,.04)';this.style.borderColor='#e2e8f0'">
                                <div style="display:flex;align-items:center;gap:6px;">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                                    <span style="font-size:10px;color:#94a3b8;margin-left:auto;">{{ child.id }}</span>
                                </div>
                                <span style="font-size:13px;font-weight:600;color:#1e293b;line-height:1.3;word-break:break-word;">{{ ez_content_name(childContent) }}</span>
                                <code style="font-size:9px;color:#94a3b8;font-family:ui-monospace,monospace;">{{ childContent.contentType.identifier }}</code>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>


            {# ── Content Type Schema (dark terminal card) ── #}
            <div style="margin-top:28px;background:#0f172a;border-radius:12px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.22);">

                <div style="padding:12px 18px;border-bottom:1px solid #1e293b;display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:#475569;">Content Type Schema</span>
                    <code style="font-size:11px;color:#38bdf8;font-family:ui-monospace,monospace;">{{ ct ? ct.identifier : '—' }}</code>
                    <span style="margin-left:auto;font-size:10px;color:#334155;font-family:ui-monospace,monospace;">
                        {{ ct ? ct.fieldDefinitions|length : 0 }} field{{ (ct ? ct.fieldDefinitions|length : 0) != 1 ? 's' : '' }}
                    </span>
                </div>

                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;font-size:12px;font-family:ui-monospace,monospace;">
                        <thead>
                            <tr style="background:#151f2e;">
                                {% for col in ['Identifier', 'Label', 'Field Type', 'Req', 'Value'] %}
                                    <th style="text-align:left;padding:8px 18px;color:#475569;font-size:10px;text-transform:uppercase;letter-spacing:.07em;white-space:nowrap;">{{ col }}</th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for fieldDef in (ct ? ct.fieldDefinitions : []) %}
                                {% set empty = ez_is_field_empty(content, fieldDef.identifier) %}
                                <tr style="border-top:1px solid #1a2535;{{ not empty ? 'background:rgba(74,222,128,.04);' : '' }}">
                                    <td style="padding:7px 18px;color:#38bdf8;white-space:nowrap;">{{ fieldDef.identifier }}</td>
                                    <td style="padding:7px 18px;color:#cbd5e1;">{{ fieldDef.names|first|default('—') }}</td>
                                    <td style="padding:7px 18px;color:#a78bfa;white-space:nowrap;">{{ fieldDef.fieldTypeIdentifier }}</td>
                                    <td style="padding:7px 18px;color:{{ fieldDef.isRequired ? '#f87171' : '#334155' }};text-align:center;">{{ fieldDef.isRequired ? '✓' : '·' }}</td>
                                    <td style="padding:7px 18px;color:{{ not empty ? '#4ade80' : '#334155' }};font-weight:{{ not empty ? '700' : '400' }};text-align:center;">{{ not empty ? '✓' : '—' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>{# /schema #}

        </div>{# /main column #}


        {# ┌─────────────────────────────────────────┐
           │  SIDEBAR                                │
           └─────────────────────────────────────────┘ #}
        {#
            Sidebar extracted to the standard parts template.
            Widget partials live at:
                templates/themes/standard/parts/content_sidebar/metadata_card.html.twig
                templates/themes/standard/parts/content_sidebar/navigate_card.html.twig
                templates/themes/standard/parts/content_sidebar/rest_api_card.html.twig
                templates/themes/standard/parts/content_sidebar/ecosystem_card.html.twig
            Coordinator: templates/themes/standard/parts/content_sidebar.html.twig
        #}
        {% include '@ezdesign/parts/content_sidebar.html.twig' with {
            content:  content,
            location: location,
            ct:       ct,
            ci:       ci,
            vi:       vi,
            lpath:    lpath,
        } only %}

    </div>{# /layout #}

</div>{# /sxa-folder #}


{% endblock %}

