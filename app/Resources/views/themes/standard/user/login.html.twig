{% extends "@ezdesign/pagelayout_login.html.twig" %}

{% block page_title %}Login — Exponential Platform{% endblock %}

{% block content %}
<div class="lp-login-box">

    <h1>Sign in</h1>

    {% if error is defined and error %}
    <div class="lp-alert lp-alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post" action="{{ path('login_check') }}" class="lp-login-form">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="lp-form-group">
            <label for="username">Username</label>
            <input type="text" id="username" name="_username" value="{{ last_username|default('') }}" required autofocus autocomplete="username">
        </div>

        <div class="lp-form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="_password" required autocomplete="current-password">
        </div>

        <div class="lp-form-actions">
            <button type="submit" class="lp-btn lp-btn-primary">Sign in</button>
        </div>
    </form>

</div>
{% endblock %}
