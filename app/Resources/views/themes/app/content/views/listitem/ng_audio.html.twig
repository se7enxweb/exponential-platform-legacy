{# content \Netgen\IbexaSiteApi\API\Values\Content #}
{# location \Netgen\IbexaSiteApi\API\Values\Location #}

{% import 'themes/app/content/macros/content_fields.html.twig' as content_fields %}


<article class="view-type view-type-{{ view_type }} ng-audio vl6 t1">
    <h3 class="title">
        <a href="{{ ez_path(location) }}">
            <i class="icon-volume-up article-icon" aria-hidden="true"></i>{{ content_fields.title(content) }}
        </a>
    </h3>

    {% if with_intro|default(false) %}
        {{ content_fields.intro(content) }}
    {% endif %}
</article>
