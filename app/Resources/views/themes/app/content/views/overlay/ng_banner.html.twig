{# content \Netgen\IbexaSiteApi\API\Values\Content #}
{# location \Netgen\IbexaSiteApi\API\Values\Location #}

{% import "themes/app/content/macros/links.html.twig" as links %}


<article class="view-type view-type-{{ view_type }} ng-banner vl2">
    <figure class="image">
        {{ links.image_link(content, 'image', 'i480') }}
    </figure>
    <header class="article-header">
        <h3 class="title">
            {{ links.content_link(content, content.fields.title.value.text) }}
        </h3>
    </header>
</article>
