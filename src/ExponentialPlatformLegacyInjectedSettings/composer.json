{
    "name": "se7enxweb/exponential-platform-legacy-injected-settings",
    "description": "Symfony bundle for Exponential Platform Legacy (eZ Platform / Ibexa OSS) that injects legacy INI settings into the eZ Publish legacy kernel at boot time via YAML configuration.",
    "type": "symfony-bundle",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "ezplatform",
        "ibexa",
        "ezpublish",
        "legacy",
        "legacy-bridge",
        "ini",
        "injected-settings",
        "exponential",
        "exponential-platform",
        "symfony",
        "se7enxweb",
        "symfony-bundle"
    ],
    "homepage": "https://github.com/se7enxweb/exponential-platform-legacy-injected-settings",
    "support": {
        "issues": "https://github.com/se7enxweb/exponential-platform-legacy/issues",
        "source": "https://github.com/se7enxweb/exponential-platform-legacy-injected-settings"
    },
    "authors": [
        {
            "name": "7x / se7enxweb",
            "homepage": "https://se7enx.com",
            "role": "Lead Developer"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^5.4 || ^6.0",
        "se7enxweb/legacy-bridge": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\ExponentialPlatformLegacyInjectedSettings\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\ExponentialPlatformLegacyInjectedSettings\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
