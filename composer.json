{
    "name": "se7enxweb/exponential-platform-legacy-skeleton",
    "type": "project",
    "license": "(GPL-2.0-or-later or proprietary)",
    "description": "A project skeleton for installing 7x Exponential Platform Legacy (Open Source)",
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-gd": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-xsl": "*",
        "ext-xml": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "nyholm/psr7": "^1.0",
        "se7enxweb/exponential-platform-legacy": "dev-master",
        "symfony/flex": "^2",
        "symfony/runtime": "^7.3"
    },
    "require-dev": {
        "symfony/debug-bundle": "^7.3",
        "symfony/stopwatch": "^7.3",
        "symfony/web-profiler-bundle": "^7.3"
    },
    "config": {
        "allow-plugins": {
            "ibexa/post-install": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "*": false
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": false,
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "^7.3",
            "endpoint": [
                "https://api.github.com/repos/ibexa/recipes/contents/index.json?ref=flex/main",
                "https://api.github.com/repos/se7enxweb/sevenx-recipes/contents/index.json?ref=master",
                "flex://defaults"
            ],
            "docker": false
        },
        "branch-alias": {
            "dev-master": "5.0.x-dev"
        }
    }
}
