{
    "name": "se7enxweb/exponential-platform-legacy",
    "type": "project",
    "license": "(GPL-2.0-or-later or proprietary)",
    "description": "A project skeleton for installing 7x Exponential Platform Legacy (Platform v5; Open Source)",
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-gd": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-xsl": "*",
        "ext-xml": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "netgen/layouts-ibexa": "^1.4",
        "netgen/layouts-standard": "^1.4",
        "nyholm/psr7": "^1.0",
        "se7enxweb/exponential-platform-dxp": "5.x-LB-dev",
        "se7enxweb/legacy-bridge": "^4.0.0.0",
        "se7enxweb/ngsymfonytools": "^4.0.0.0",
        "se7enxweb/richtext-datatype-bundle": "*",
        "se7enxweb/ezplatform-xmltext-fieldtype": "4.x-dev",
        "se7enxweb/site-legacy-bundle": "^2.0",
        "symfony/flex": "^2",
        "symfony/runtime": "^7.3"
    },
    "require-dev": {
        "symfony/debug-bundle": "^7.3",
        "symfony/stopwatch": "^7.3",
        "symfony/web-profiler-bundle": "^7.3"
    },
    "config": {
        "allow-plugins": {
            "ibexa/post-install": true,
            "se7enxweb/exponential-legacy-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "*": false
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "bazinga:js-translation:dump public/assets --merge-domains": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
            "ezpublish:legacy:assets_install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
            "ezpublish:legacybundles:install_extensions --relative": "symfony-cmd",
            "cache:clear": "symfony-cmd"
        },
        "project-scripts": [
            "@php bin/console ezpublish:legacy:script bin/php/ezpgenerateautoloads.php"
        ],
        "post-install-cmd": [
            "php bin/install-legacy-links",
            "@auto-scripts",
            "@project-scripts"
        ],
        "post-update-cmd": [
            "php bin/install-legacy-links",
            "@auto-scripts",
            "@project-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": false,
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "^7.3",
            "endpoint": [
                "https://api.github.com/repos/ibexa/recipes/contents/index.json?ref=flex/main",
                "https://api.github.com/repos/se7enxweb/sevenx-recipes/contents/index.json?ref=master",
                "flex://defaults"
            ],
            "docker": false
        },
        "ezpublish-legacy-dir": "ezpublish_legacy",
        "branch-alias": {
            "dev-master": "5.0.x-dev"
        }
    }
}
