{
    "name": "se7enxweb/exponential-platform-legacy",
    "type": "project",
    "license": [
        "(GPL-2.0-or-later or proprietary)"
    ],
    "description": "Exponential Platform Legacy 3 — Provides Exponential Platform 3 + Symfony 5.4 LTS + PHP 8.x + Legacy Bridge (No Netgen Packages)",
    "homepage": "https://platform.exponential.earth",
    "authors": [
        {
            "name": "7x",
            "homepage": "https://se7enx.com"
        },
        {
            "name": "eZ Systems / Ibexa dev team & community",
            "homepage": "https://github.com/ezsystems"
        }
    ],
    "require": {
        "php": "^8.0",
        "ext-gd": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-xsl": "*",
        "ext-xml": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "se7enxweb/oss": "~3.3.0",
        "se7enxweb/legacy-bridge": "^3.0",
        "se7enxweb/symfony": "5.4.x-dev",
        "symfony/flex": "^1.17|^2",
        "symfony/console": "5.4.*",
        "symfony/dotenv": "5.4.*",
        "symfony/framework-bundle": "5.4.*",
        "symfony/runtime": "5.4.*",
        "symfony/yaml": "5.4.*",
        "sentry/sentry-symfony": "^4.0",
        "twig/twig": "^3.0",
        "twig/intl-extra": "^3.0",
        "se7enxweb/ezplatform-kernel": "~1.3",
        "se7enxweb/ezplatform-rest": "~1.3.27",
        "se7enxweb/ezplatform-content-forms": "~1.3.19",
        "se7enxweb/ezplatform-http-cache": "~2.3.19",
        "se7enxweb/ezplatform-richtext": "~2.3.26",
        "se7enxweb/mediata-ezpage-fieldtype-bundle": "~3.3",
        "se7enxweb/ezmigrationbundle": "^6.0",
        "se7enxweb/ezseobundle": "~3.3",
        "se7enxweb/ez-core-extra-bundle": "3.0.0",
        "contextualcode/ezplatform-alloyeditor-element-width": "^2.0"
    },
    "require-dev": {
        "symfony/debug-bundle": "5.4.*",
        "symfony/maker-bundle": "^1.0",
        "symfony/web-profiler-bundle": "5.4.*",
        "deployer/recipes": "^6.2",
        "phpstan/phpstan": "^1.10",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-strict-rules": "^1.5",
        "phpstan/phpstan-symfony": "^1.3",
        "phpstan/phpstan-doctrine": "^1.3",
        "php-cs-fixer/shim": "^3.0",
        "phpunit/phpunit": "^9.5",
        "symfony/browser-kit": "5.4.*",
        "symfony/css-selector": "5.4.*",
        "symfony/phpunit-bridge": "5.4.*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "ibexa/post-install": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true,
            "se7enxweb/exponential-legacy-installer": true,
            "*": false
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "bazinga:js-translation:dump public/assets --merge-domains": "symfony-cmd",
            "assets:install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
            "ezpublish:legacy:assets_install --symlink --relative %PUBLIC_DIR%": "symfony-cmd",
            "ezpublish:legacybundles:install_extensions --relative": "symfony-cmd"
        },
        "project-scripts": [
            "@php bin/console ezpublish:legacy:script bin/php/ezpgenerateautoloads.php"
        ],
        "post-install-cmd": [
            "@auto-scripts",
            "@project-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts",
            "@project-scripts"
        ],
        "phpstan": "@php vendor/bin/phpstan analyse -c phpstan.neon --level=8 --ansi src tests"
    },
    "conflict": {
    },
    "extra": {
        "ezpublish-legacy-dir": "ezpublish_legacy",
        "symfony": {
            "allow-contrib": true,
            "require": "5.4.*",
            "endpoint": [
                "https://api.github.com/repos/se7enxweb/sevenx-recipes/contents/index.json?ref=master",
                "flex://defaults"
            ],
            "docker": false
        },
        "branch-alias": {
            "dev-3.x": "3.x-dev"
        }
    }
}
