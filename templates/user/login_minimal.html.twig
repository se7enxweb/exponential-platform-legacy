<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <title>Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
</head>
<body>
    <form action="{{ path('login_check') }}" method="post">
        {% if error %}
            <p style="color:red">{{ error.message|trans }}</p>
        {% endif %}
        <label for="username">Username:</label>
        <input type="text" id="username" name="_username" value="{{ last_username }}" autofocus required /><br />
        <label for="password">Password:</label>
        <input type="password" id="password" name="_password" required /><br />
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />
        <button type="submit">Login</button>
    </form>
</body>
</html>
