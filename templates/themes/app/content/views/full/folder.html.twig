{# standard/content/views/full/folder.html.twig — minimalistic info-style folder view (copied from sevenx-content-website-app) #}

{% extends pagelayout is defined ? pagelayout : "@ezdesign/pagelayout.html.twig" %}

{% block page_title -%}
{%- set _name = ez_content_name(content) -%}
{%- set _alias = path('ez_urlalias', {locationId: location.id})|trim('/') -%}
{%- set _raw_parts = (_alias and not (_alias starts with 'view/')) ? _alias|split('/') : [] -%}
{%- set _parent_parts = [] -%}
{%- for part in _raw_parts|slice(0, -1) -%}{%- set _parent_parts = _parent_parts|merge([part|replace({'-': ' ', '_': ' '})|title]) -%}{%- endfor -%}
{%- set _path_label = _parent_parts|length > 0 ? (_parent_parts|join(' / ') ~ ' / ' ~ _name) : _name -%}
{{ _path_label }} - Exponential Platform is The Power User's CMS / DXP
{%- endblock %}

{% block content %}

{%- set ct    = content.contentType is defined ? content.contentType : null -%}
{%- set ci    = content.contentInfo is defined ? content.contentInfo : null -%}
{%- set vi    = content.versionInfo is defined ? content.versionInfo : null -%}
{%- set lpath = location.pathString|trim('/') -%}
{%- set skip  = ['name', 'short_name'] -%}

<div style="font-family:system-ui,-apple-system,sans-serif;color:#0f172a;line-height:1.55;min-width:0;">

    {# ════════════════════════════════════════════════
       HERO HEADER
    ════════════════════════════════════════════════ #}
    <div style="margin-bottom:24px;padding-bottom:20px;border-bottom:2px solid #e2e8f0;">

        {# Breadcrumb #}
        <nav aria-label="breadcrumb" style="font-size:12px;color:#94a3b8;margin-bottom:12px;display:flex;align-items:center;gap:5px;flex-wrap:wrap;">
            <a href="/" style="color:#64748b;text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Root
            </a>
            {% if location.depth > 1 %}
                <span style="opacity:.4;">›</span>
                <a href="{{ path('ez_urlalias', {locationId: location.parentLocationId}) }}" style="color:#64748b;text-decoration:none;">Parent</a>
            {% endif %}
            <span style="opacity:.4;">›</span>
            <span style="color:#1e293b;font-weight:600;">{{ ez_content_name(content) }}</span>
        </nav>

        {# Badge row #}
        <div style="display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:12px;">
            <span style="background:#dbeafe;color:#1d4ed8;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;padding:3px 11px;border-radius:20px;">
                {{ ct ? ct.identifier : '—' }}
            </span>
            <span style="background:#f0fdf4;color:#166534;font-size:10px;font-weight:700;padding:3px 11px;border-radius:20px;">
                v{{ vi ? vi.versionNo : '—' }}
            </span>
            {% if location.hidden or location.invisible %}
                <span style="background:#fef3c7;color:#92400e;font-size:10px;font-weight:700;padding:3px 11px;border-radius:20px;">⚠ Hidden</span>
            {% endif %}
        </div>

        <h1 style="margin:0 0 14px;font-size:2rem;font-weight:800;color:#0f172a;line-height:1.15;letter-spacing:-.025em;">
            {{ ez_content_name(content) }}
        </h1>

        {# Quick-reference pills #}
        <div style="display:flex;align-items:center;gap:7px;flex-wrap:wrap;">
            {% for label, val in {
                'Content': content.id,
                'Location': location.id,
                'Depth': location.depth,
                'Path': location.pathString
            } %}
                <span style="display:inline-flex;align-items:center;gap:5px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:6px;padding:3px 10px;font-size:11px;">
                    <span style="color:#94a3b8;">{{ label }}</span>
                    <code style="color:#334155;font-family:ui-monospace,monospace;">{{ val }}</code>
                </span>
            {% endfor %}
        </div>

    </div>{# /hero #}


    {# ════════════════════════════════════════════════
       TWO-COLUMN LAYOUT
    ════════════════════════════════════════════════ #}
    <div id="sxa-layout" style="display:grid;grid-template-columns:1fr 272px;gap:24px;align-items:start;">


        {# ┌─────────────────────────────────────────┐
           │  MAIN COLUMN                            │
           └─────────────────────────────────────────┘ #}
        <div style="min-width:0;">

            {# ── Dynamic field cards ── #}
            {% for fieldDef in (ct ? ct.fieldDefinitions : []) %}
                {% if fieldDef.identifier not in skip %}
                    {% if not ez_field_is_empty(content, fieldDef.identifier) %}
                        <div style="margin-bottom:18px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04);">
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;padding:9px 16px;background:#f8fafc;border-bottom:1px solid #f1f5f9;">
                                <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#475569;">
                                    {{ fieldDef.names|first|default(fieldDef.identifier) }}
                                </span>
                                <code style="font-size:10px;font-family:ui-monospace,monospace;color:#94a3b8;background:#eef2f7;padding:1px 7px;border-radius:4px;white-space:nowrap;">{{ fieldDef.fieldTypeIdentifier }}</code>
                            </div>
                            <div style="padding:14px 16px;font-size:14px;color:#334155;line-height:1.7;word-break:break-word;overflow-x:auto;">
                                {{ ez_render_field(content, fieldDef.identifier) }}
                            </div>
                        </div>
                    {% endif %}
                {% endif %}
            {% endfor %}


            {# ── Contents ── #}
            {%- set children = ez_location_children(location, 50) -%}
            <div style="margin-bottom:28px;">
                <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:12px;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748b;">Contents</span>
                    <span style="font-size:10px;color:#94a3b8;font-family:ui-monospace,monospace;">{{ children|length }} item{{ children|length != 1 ? 's' : '' }}</span>
                </div>
                {% if children|length == 0 %}
                    <div style="padding:20px;text-align:center;color:#94a3b8;font-size:12px;border:1px dashed #e2e8f0;border-radius:8px;">
                        This folder is empty.
                    </div>
                {% else %}
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">
                        {% for child in children %}
                            {%- set childContent = child.getContent() -%}
                            <a href="{{ path('ez_urlalias', {locationId: child.id}) }}"
                               style="display:flex;flex-direction:column;gap:6px;padding:12px 14px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;text-decoration:none;box-shadow:0 1px 3px rgba(0,0,0,.04);"
                               onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,.10)';this.style.borderColor='#bfdbfe'"
                               onmouseout="this.style.boxShadow='0 1px 3px rgba(0,0,0,.04)';this.style.borderColor='#e2e8f0'">
                                <div style="display:flex;align-items:center;gap:6px;">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                                    <span style="font-size:10px;color:#94a3b8;margin-left:auto;">{{ child.id }}</span>
                                </div>
                                <span style="font-size:13px;font-weight:600;color:#1e293b;line-height:1.3;word-break:break-word;">{{ ez_content_name(childContent) }}</span>
                                <code style="font-size:9px;color:#94a3b8;font-family:ui-monospace,monospace;">{{ childContent.contentType.identifier }}</code>
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>


            {# ── Content Type Schema (dark terminal card) ── #}
            <div style="margin-top:28px;background:#0f172a;border-radius:12px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.22);">

                <div style="padding:12px 18px;border-bottom:1px solid #1e293b;display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:#475569;">Content Type Schema</span>
                    <code style="font-size:11px;color:#38bdf8;font-family:ui-monospace,monospace;">{{ ct ? ct.identifier : '—' }}</code>
                    <span style="margin-left:auto;font-size:10px;color:#334155;font-family:ui-monospace,monospace;">
                        {{ ct ? ct.fieldDefinitions|length : 0 }} field{{ (ct ? ct.fieldDefinitions|length : 0) != 1 ? 's' : '' }}
                    </span>
                </div>

                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;font-size:12px;font-family:ui-monospace,monospace;">
                        <thead>
                            <tr style="background:#151f2e;">
                                {% for col in ['Identifier', 'Label', 'Field Type', 'Req', 'Value'] %}
                                    <th style="text-align:left;padding:8px 18px;color:#475569;font-size:10px;text-transform:uppercase;letter-spacing:.07em;white-space:nowrap;">{{ col }}</th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for fieldDef in (ct ? ct.fieldDefinitions : []) %}
                                {% set empty = ez_field_is_empty(content, fieldDef.identifier) %}
                                <tr style="border-top:1px solid #1a2535;{{ not empty ? 'background:rgba(74,222,128,.04);' : '' }}">
                                    <td style="padding:7px 18px;color:#38bdf8;white-space:nowrap;">{{ fieldDef.identifier }}</td>
                                    <td style="padding:7px 18px;color:#cbd5e1;">{{ fieldDef.names|first|default('—') }}</td>
                                    <td style="padding:7px 18px;color:#a78bfa;white-space:nowrap;">{{ fieldDef.fieldTypeIdentifier }}</td>
                                    <td style="padding:7px 18px;color:{{ fieldDef.isRequired ? '#f87171' : '#334155' }};text-align:center;">{{ fieldDef.isRequired ? '✓' : '·' }}</td>
                                    <td style="padding:7px 18px;color:{{ not empty ? '#4ade80' : '#334155' }};font-weight:{{ not empty ? '700' : '400' }};text-align:center;">{{ not empty ? '✓' : '—' }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>{# /schema #}

        </div>{# /main column #}


        {# ┌─────────────────────────────────────────┐
           │  SIDEBAR                                │
           └─────────────────────────────────────────┘ #}
        <div style="display:flex;flex-direction:column;gap:14px;">


            {# ── Metadata card ── #}
            <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04);">
                <div style="padding:10px 14px;background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748b;">Metadata</span>
                </div>
                <div style="padding:10px 14px;">
                    {% set meta_items = [
                        ['Content ID',   content.id,                    true],
                        ['Location ID',  location.id,                   true],
                        ['Parent Loc.',  location.parentLocationId,     true],
                        ['Main Loc.',    ci ? ci.mainLocationId : '—',         true],
                        ['Section',      ci ? ci.sectionId : '—',              true],
                        ['Owner ID',     ci ? ci.ownerId : '—',                true],
                        ['Version',      vi ? vi.versionNo : '—',              true],
                        ['Depth',        location.depth,                true],
                        ['Priority',     location.priority,             true],
                        ['Hidden',       location.hidden ? '⚠ Yes' : 'No', false],
                        ['Path',         location.pathString,           true],
                        ['Published',    ci ? ci.publishedDate|date('Y-m-d') : '—',    false],
                        ['Modified',     ci ? ci.modificationDate|date('Y-m-d') : '—', false],
                    ] %}
                    {% for row in meta_items %}
                        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;padding:5px 0;border-bottom:1px solid #f8fafc;">
                            <span style="font-size:12px;color:#64748b;white-space:nowrap;flex-shrink:0;">{{ row[0] }}</span>
                            {% if row[2] %}
                                <code style="font-size:10px;font-family:ui-monospace,monospace;color:#334155;background:#f1f5f9;padding:1px 7px;border-radius:3px;max-width:155px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;">{{ row[1] }}</code>
                            {% else %}
                                <span style="font-size:12px;color:#334155;font-weight:500;">{{ row[1] }}</span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>


            {# ── Navigate card ── #}
            <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04);">
                <div style="padding:10px 14px;background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748b;">Navigate</span>
                </div>
                <nav style="padding:6px 8px;display:flex;flex-direction:column;gap:1px;" aria-label="System navigation">
                    {% set nav_links = [
                        ['↑', 'Parent Folder',      path('ez_urlalias', {locationId: location.parentLocationId}), '#0369a1', false],
                        ['🏠', 'Root / Home',        '/',                                                           '#059669', false],
                        ['⚙', 'Admin Interface',    '/adminui/',                                                   '#7c3aed', true],
                        ['🔐', 'Login',              '/login',                                                      '#374151', false],
                        ['📤', 'Logout',             '/logout',                                                     '#374151', false],
                        ['🔍', 'REST API Root',      '/api/ezp/v2/',                                                '#0891b2', true],
                    ] %}
                    {% for item in nav_links %}
                        <a href="{{ item[2] }}"{{ item[4] ? ' target="_top"' : '' }}
                           style="display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:7px;text-decoration:none;color:{{ item[3] }};font-size:12px;font-weight:500;"
                           onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='transparent'">
                            <span style="width:16px;text-align:center;flex-shrink:0;font-style:normal;">{{ item[0] }}</span>
                            {{ item[1] }}
                        </a>
                    {% endfor %}
                </nav>
            </div>


            {# ── REST API card (dark) ── #}
            <div style="background:#0f172a;border:1px solid #1e293b;border-radius:10px;overflow:hidden;">
                <div style="padding:10px 14px;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:8px;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#475569;">REST API</span>
                    <code style="font-size:9px;color:#38bdf8;font-family:ui-monospace,monospace;background:rgba(56,189,248,.1);padding:1px 6px;border-radius:3px;">v2</code>
                </div>
                <div style="padding:6px 8px;display:flex;flex-direction:column;gap:1px;">
                    {% set api_links = [
                        ['API Root',         '/api/ezp/v2/'],
                        ['Content Object',   '/api/ezp/v2/content/objects/' ~ content.id],
                        ['Location',         '/api/ezp/v2/content/locations/' ~ lpath],
                        ['Children',         '/api/ezp/v2/content/locations/' ~ lpath ~ '/children'],
                        ['Content Type',     '/api/ezp/v2/content/types/' ~ (ct ? ct.id : 0)],
                        ['URL Aliases',      '/api/ezp/v2/content/urlaliases?locationId=' ~ location.id],
                        ['Versions',         '/api/ezp/v2/content/objects/' ~ content.id ~ '/versions'],
                        ['Relations',        '/api/ezp/v2/content/objects/' ~ content.id ~ '/' ~ (vi ? vi.versionNo : 1) ~ '/relations'],
                        ['Sections',         '/api/ezp/v2/content/sections'],
                        ['User Sessions',    '/api/ezp/v2/user/sessions'],
                    ] %}
                    {% for api in api_links %}
                        <a href="{{ api[1] }}" target="_blank"
                           style="display:flex;align-items:center;gap:7px;padding:7px 10px;border-radius:6px;text-decoration:none;font-size:11px;color:#94a3b8;font-family:ui-monospace,monospace;"
                           onmouseover="this.style.background='#1e293b';this.style.color='#e2e8f0'" onmouseout="this.style.background='transparent';this.style.color='#94a3b8'">
                            <span style="font-size:9px;font-weight:700;color:#4ade80;background:rgba(74,222,128,.1);padding:1px 5px;border-radius:3px;flex-shrink:0;">GET</span>
                            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ api[0] }}</span>
                        </a>
                    {% endfor %}
                </div>
            </div>


            {# ── Ecosystem card ── #}
            <div style="background:#fff;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04);">
                <div style="padding:10px 14px;background:#f8fafc;border-bottom:1px solid #e2e8f0;">
                    <span style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748b;">Ecosystem</span>
                </div>
                <nav style="padding:6px 8px;display:flex;flex-direction:column;gap:1px;">
                    {% set eco_links = [
                        ['exponential.earth',  'https://exponential.earth',                '#6366f1'],
                        ['Platform Docs',      'https://doc.exponential.earth',            '#7c3aed'],
                        ['x.Doc',              'https://exponential.doc.exponential.earth/display/MAIN/ExponentialPlatformDocumentationCenter.html', '#d97706'],
                        ['Share',              'https://share.exponential.earth',          '#059669'],
                        ['API Reference',      'https://api.exponential.earth',            '#dc2626'],
                        ['GitHub — se7enxweb', 'https://github.com/se7enxweb',            '#374151'],
                        ['This Repo',          'https://github.com/se7enxweb/exponential-platform-legacy', '#374151'],
                    ] %}
                    {% for item in eco_links %}
                        <a href="{{ item[1] }}" target="_blank" rel="noopener"
                           style="display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:7px;text-decoration:none;color:{{ item[2] }};font-size:12px;font-weight:500;"
                           onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='transparent'">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;opacity:.55;"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                            {{ item[0] }}
                        </a>
                    {% endfor %}
                </nav>
            </div>


        </div>{# /sidebar #}
    </div>{# /layout #}

</div>{# /sxa-folder #}


{% endblock %}

