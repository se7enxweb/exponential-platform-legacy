{# content \Netgen\IbexaSiteApi\API\Values\Content #}
{# location \Netgen\IbexaSiteApi\API\Values\Location #}

{% import 'themes/app/content/macros/content_fields.html.twig' as content_fields %}


<article class="view-type view-type-{{ view_type }} ng-article vl5">
    {{ content_fields.image(content, location, 'i160') }}

    <header class="article-header">
        <h3 class="title"><a href="{{ ez_path(location) }}">{{ content_fields.title(content) }}</a></h3>
        <div class="info">
            {% include 'themes/app/content/parts/author.html.twig' %}
        </div>
    </header>
</article>
