{# ── Quick list — ALL children ──
   Variables: children
#}
<div class="nw-widget">
    <div class="nw-whead">
        <div class="nw-whead-dot"></div>
        All Content
    </div>
    <div class="nw-wbody" style="padding:8px 14px;">
        <div class="nw-qlist">
            {% for child in children %}
                {%- set cc = child.getContent() -%}
                <a href="{{ path('ez_urlalias', {locationId: child.id}) }}"
                   class="nw-qli"
                   data-card-loc="{{ child.id }}">
                    <span class="nw-qli-num">{{ loop.index }}</span>
                    <div class="nw-qli-info">
                        <div class="nw-qli-title">{{ ez_content_name(cc) }}</div>
                        <div class="nw-qli-type">{{ cc.contentType.identifier }}</div>
                    </div>
                </a>
            {% else %}
                <p style="font-size:12px;color:#8b949e;text-align:center;padding:12px 0;">No items.</p>
            {% endfor %}
        </div>
    </div>
</div>
