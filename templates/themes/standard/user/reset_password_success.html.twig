{#
    standard/user/reset_password_success.html.twig

    Shown after a password has been successfully reset.
    Template config key: user_reset_password.templates.success
    Controller: PasswordResetController::userResetPasswordAction (after valid submit)
#}
{% extends '@ezdesign/pagelayout_login.html.twig' %}

{% block page_title %}Password Updated | Exponential Platform{% endblock %}

{% block content %}
<div class="lp-login-wrap">
    <div class="lp-login-card">

        <div class="lp-login-logo">
            <a href="/"><img src="/assets/images/exponentialplatform.png" alt="Exponential Platform"></a>
        </div>

        <h1 class="lp-login-title">Password Updated</h1>
        <p class="lp-login-sub">
            Your password has been changed successfully.
            You can now sign in with your new credentials.
        </p>

        <a href="{{ path('login') }}" class="lp-login-submit" style="display:block; text-align:center; text-decoration:none; line-height:2.6;">
            Sign In
        </a>

    </div>
</div>

<div class="lp-login-footer">
    &copy; 1998&ndash;{{ "now"|date("Y") }} <a href="https://se7enx.com" target="_blank" rel="noopener">7x</a>.
    Powered by <a href="https://exponential.earth" target="_blank" rel="noopener">Exponential</a>.
</div>
{% endblock %}
