{#
    standard/user/register_confirmation.html.twig

    Shown after a registration is successfully submitted (awaiting activation).
    Template config key: user_registration.templates.confirmation
    Controller: UserRegisterController::registerConfirmAction
    Route: exp_user_register_confirmation → /register-confirm
#}
{% extends '@ezdesign/pagelayout_login.html.twig' %}

{% block page_title %}Registration Submitted | Exponential Platform{% endblock %}

{% block content %}
<div class="lp-login-wrap">
    <div class="lp-login-card">

        <div class="lp-login-logo">
            <a href="/"><img src="/assets/images/exponentialplatform.png" alt="Exponential Platform"></a>
        </div>

        <h1 class="lp-login-title">Registration Submitted</h1>
        <p class="lp-login-sub">
            Your account registration has been received.
            You will be notified by email once your account is activated.
        </p>

        <div class="lp-login-links" style="justify-content: center; margin-top: 28px;">
            <a href="{{ path('login') }}">&larr; Back to sign in</a>
        </div>

    </div>
</div>

<div class="lp-login-footer">
    &copy; 1998&ndash;{{ "now"|date("Y") }} <a href="https://se7enx.com" target="_blank" rel="noopener">7x</a>.
    Powered by <a href="https://exponential.earth" target="_blank" rel="noopener">Exponential</a>.
</div>
{% endblock %}
