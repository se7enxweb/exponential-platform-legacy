{#
    standard/user/forgot_password_success.html.twig

    Shown after a forgot-password request is successfully submitted.
    Template config key: user_forgot_password_success.templates.form
    Controller: PasswordResetController::userForgotPasswordAction (after valid submit)
#}
{% extends '@ezdesign/pagelayout_login.html.twig' %}

{% block page_title %}Check Your Email | Exponential Platform{% endblock %}

{% block content %}
<div class="lp-login-wrap">
    <div class="lp-login-card">

        <div class="lp-login-logo">
            <a href="/"><img src="/assets/images/exponentialplatform.png" alt="Exponential Platform"></a>
        </div>

        <h1 class="lp-login-title">Check Your Email</h1>
        <p class="lp-login-sub">
            If an account exists for that address, you&rsquo;ll receive a password reset link shortly.
            Check your spam folder if it doesn&rsquo;t arrive within a few minutes.
        </p>

        <div class="lp-login-links" style="justify-content: center; margin-top: 28px;">
            <a href="{{ path('login') }}">&larr; Back to sign in</a>
        </div>

    </div>
</div>

<div class="lp-login-footer">
    &copy; 1998&ndash;{{ "now"|date("Y") }} <a href="https://se7enx.com" target="_blank" rel="noopener">7x</a>.
    Powered by <a href="https://exponential.earth" target="_blank" rel="noopener">Exponential</a>.
</div>
{% endblock %}
