{#
    standard/user/reset_password.html.twig

    Set-new-password form (reached via emailed hash link).
    Template config key: user_reset_password.templates.form
    Controller: PasswordResetController::userResetPasswordAction
    Form variable: form_reset_user_password
    Fields: new_password.first (new), new_password.second (confirm)
    Route: exp_user_reset_password → /user/reset-password/{hashKey}
#}
{% extends '@ezdesign/pagelayout_login.html.twig' %}

{% block page_title %}Reset Password | Exponential Platform{% endblock %}

{% block content %}
<div class="lp-login-wrap">
    <div class="lp-login-card">

        <div class="lp-login-logo">
            <a href="/"><img src="/assets/images/exponentialplatform.png" alt="Exponential Platform"></a>
        </div>

        <h1 class="lp-login-title">Set New Password</h1>
        <p class="lp-login-sub">Choose a strong password for your account.</p>

        {{ form_start(form_reset_user_password) }}

        {{ form_errors(form_reset_user_password) }}

        <div class="lp-login-field">
            <label for="{{ form_reset_user_password.new_password.first.vars.id }}">New password</label>
            {{ form_widget(form_reset_user_password.new_password.first, {
                'attr': { 'placeholder': 'Enter new password', 'autocomplete': 'new-password' }
            }) }}
            {{ form_errors(form_reset_user_password.new_password.first) }}
        </div>

        <div class="lp-login-field">
            <label for="{{ form_reset_user_password.new_password.second.vars.id }}">Confirm password</label>
            {{ form_widget(form_reset_user_password.new_password.second, {
                'attr': { 'placeholder': 'Confirm new password', 'autocomplete': 'new-password' }
            }) }}
            {{ form_errors(form_reset_user_password.new_password.second) }}
        </div>

        <button type="submit" class="lp-login-submit">Update Password</button>

        {{ form_rest(form_reset_user_password) }}
        {{ form_end(form_reset_user_password) }}

    </div>
</div>

<div class="lp-login-footer">
    &copy; 1998&ndash;{{ "now"|date("Y") }} <a href="https://se7enx.com" target="_blank" rel="noopener">7x</a>.
    Powered by <a href="https://exponential.earth" target="_blank" rel="noopener">Exponential</a>.
</div>
{% endblock %}
