{#
    standard/user/forgot_password.html.twig

    Forgot-password request form.
    Template config key: user_forgot_password.templates.form
    Controller: PasswordResetController::userForgotPasswordAction
    Form variable: form_forgot_user_password (field: email)
    Route: exp_user_forgot_password → /user/forgot-password
#}
{% extends '@ezdesign/pagelayout_login.html.twig' %}

{% block page_title %}Forgot Password | Exponential Platform{% endblock %}

{% block content %}
<div class="lp-login-wrap">
    <div class="lp-login-card">

        <div class="lp-login-logo">
            <a href="/"><img src="/assets/images/exponentialplatform.png" alt="Exponential Platform"></a>
        </div>

        <h1 class="lp-login-title">Forgot Password</h1>
        <p class="lp-login-sub">Enter your email address and we&rsquo;ll send you a reset link.</p>

        {{ form_start(form_forgot_user_password) }}

        {{ form_errors(form_forgot_user_password) }}

        <div class="lp-login-field">
            <label for="{{ form_forgot_user_password.email.vars.id }}">Email address</label>
            {{ form_widget(form_forgot_user_password.email, {
                'attr': { 'placeholder': 'Enter your email address', 'autocomplete': 'email' }
            }) }}
            {{ form_errors(form_forgot_user_password.email) }}
        </div>

        <button type="submit" class="lp-login-submit">Send Reset Link</button>

        <div class="lp-login-submit-alt-wrap">
            {{ form_widget(form_forgot_user_password.reset, {
                'attr': { 'class': 'lp-login-submit lp-login-submit--sm' }
            }) }}
        </div>

        {{ form_rest(form_forgot_user_password) }}
        {{ form_end(form_forgot_user_password) }}

        <div class="lp-login-links">
            <a href="{{ path('login') }}">&larr; Back to sign in</a>
        </div>

    </div>
</div>

<div class="lp-login-footer">
    &copy; 1998&ndash;{{ "now"|date("Y") }} <a href="https://se7enx.com" target="_blank" rel="noopener">7x</a>.
    Powered by <a href="https://exponential.earth" target="_blank" rel="noopener">Exponential</a>.
</div>
{% endblock %}
