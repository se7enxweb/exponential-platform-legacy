{#
    standard/user/reset_password_invalid_link.html.twig

    Shown when the password-reset hash link is expired or invalid.
    Template config key: user_reset_password.templates.invalid_link
    Controller: PasswordResetController::userResetPasswordAction
#}
{% extends '@ezdesign/pagelayout_login.html.twig' %}

{% block page_title %}Invalid Reset Link | Exponential Platform{% endblock %}

{% block content %}
<div class="lp-login-wrap">
    <div class="lp-login-card">

        <div class="lp-login-logo">
            <a href="/"><img src="/assets/images/exponentialplatform.png" alt="Exponential Platform"></a>
        </div>

        <h1 class="lp-login-title">Link Expired</h1>

        <div class="lp-login-error">
            This password reset link is no longer valid. Reset links expire after use or after 24 hours.
        </div>

        <p class="lp-login-sub" style="margin-top: 20px;">
            Request a new link below to reset your password.
        </p>

        <a href="{{ path('exp_user_forgot_password') }}" class="lp-login-submit" style="display:block; text-align:center; text-decoration:none; line-height:2.6; margin-top:8px;">
            Request New Link
        </a>

        <div class="lp-login-links" style="justify-content: center; margin-top: 16px;">
            <a href="{{ path('login') }}">&larr; Back to sign in</a>
        </div>

    </div>
</div>

<div class="lp-login-footer">
    &copy; 1998&ndash;{{ "now"|date("Y") }} <a href="https://se7enx.com" target="_blank" rel="noopener">7x</a>.
    Powered by <a href="https://exponential.earth" target="_blank" rel="noopener">Exponential</a>.
</div>
{% endblock %}
