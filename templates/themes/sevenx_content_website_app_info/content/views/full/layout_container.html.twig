                    <div class="nw-mhd-ftags">
                        <span class="nw-mhd-ftag">{{ ct is not null ? ct.identifier : '' }}</span>
                        <span class="nw-mhd-ftag-dim">loc:{{ location.id }}</span>
                        <span class="nw-mhd-ftag-dim">depth:{{ location.depth }}</span>
                        {% if children|length > 0 %}<span class="nw-mhd-ftag-dim">{{ children|length }}&nbsp;items</span>{% endif %}
                        <span class="nw-mhd-ftag-dim">content:{{ content.id }}</span>
                    </div>
                    <div class="nw-mhd-fname">
