<div id="nw">

{# ════════════════════════════════════════════
   ① CATEGORY NAV BAR
   ════════════════════════════════════════════ #}
<nav class="nw-catnav" aria-label="Categories">
    <div class="nw-catnav-inner">
        {% for cat in cats %}
            <a href="#"
               class="{{ ct is not null and ct.identifier|lower == cat|lower ? 'nw-active' : '' }}"
               onclick="return false;">{{ cat }}</a>
            {%- if not loop.last -%}<div class="nw-catnav-sep"></div>{%- endif -%}
        {% endfor %}
        <div class="nw-catnav-sep"></div>
        <a href="#" onclick="return false;" style="color:#e8472b;font-weight:800;">{{ ez_content_name(content) }}</a>
    </div>
</nav>

{# ════════════════════════════════════════════
   BREADCRUMB BAR
   ════════════════════════════════════════════ #}
<div class="nw-bread">
    <div class="nw-bread-inner">
        <a href="/">Home</a>
        <span class="sep">›</span>
        {% if location.depth > 1 %}
            <a href="{{ path('ez_urlalias', {locationId: location.parentLocationId}) }}">Parent</a>
            <span class="sep">›</span>
        {% endif %}
        <span class="current">{{ ez_content_name(content) }}</span>
    </div>
</div>

