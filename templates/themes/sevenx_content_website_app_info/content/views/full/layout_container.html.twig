{#
    app/content/views/full/layout_container.html.twig — HOMEPAGE LAYOUT
    ──────────────────────────────────────────────────────────────────
    Matched exclusively for Location ID 2 / Content ID 1
    ("Exponential Platform" root folder — what renders at /)

    This is the intentional homepage design:
      • Exponential Developer Journey hero — 21-discipline card grid
      • Dynamic title breadcrumb from url alias
      • Subitems card grid (if any children exist)

    Generic folders use: themes/app/content/views/full/folder.html.twig
    Routing config:      config/app/packages/ezpublish.yaml → layout_folder
    DB reference:        node_id=2 / contentobject_id=1
#}
{% extends "@ezdesign/pagelayout.html.twig" %}

{% block page_title -%}
{%- set _name = ez_content_name(content) -%}
{%- set _alias = path('ez_urlalias', {locationId: location.id})|trim('/') -%}
{%- set _raw_parts = (_alias and not (_alias starts with 'view/')) ? _alias|split('/') : [] -%}
{%- set _parent_parts = [] -%}
{%- for part in _raw_parts|slice(0, -1) -%}{%- set _parent_parts = _parent_parts|merge([part|replace({'-': ' ', '_': ' '})|title]) -%}{%- endfor -%}
{%- set _path_label = _parent_parts|length > 0 ? (_parent_parts|join(' / ') ~ ' / ' ~ _name) : _name -%}
{{ _path_label }} - Exponential Platform is The Power User's CMS / DXP
{%- endblock %}

{% block content %}
{%- set children = ez_location_children(location, 50) -%}
{%- set ct = content.contentType -%}
{%- set skip = ['name', 'short_name'] -%}

{%- set bodyFields = [] -%}
{% if ct is not null %}
{% for fd in ct.fieldDefinitions %}
    {%- if fd.identifier not in skip and not ez_field_is_empty(content, fd.identifier) -%}
        {%- set bodyFields = bodyFields|merge([fd]) -%}
    {%- endif -%}
{% endfor %}
{% endif %}

{# First text-like field = hero excerpt #}
{%- set heroExcerpt = '' -%}
{%- set heroField   = null -%}
{% for fd in bodyFields %}
    {%- if heroField is null and fd.fieldTypeIdentifier in ['ezrichtext','ezxmltext','eztext','ezstring'] -%}
        {%- set heroField   = fd -%}
        {%- set heroExcerpt = ez_render_field(content, fd.identifier)|striptags|trim|slice(0,320) -%}
    {%- endif -%}
{% endfor %}

{# Palette #}
{%- set c = {
    bg:       '#191919',
    bgBody:   '#f1f1f1',
    bgCard:   '#ffffff',
    nav:      '#111111',
    navHov:   '#e8472b',
    hero:     '#161b22',
    accent:   '#e8472b',
    accentB:  '#4a9fd4',
    hdr:      '#0e0e0e',
    txt:      '#1a1a1a',
    txtMuted: '#6b7280',
    border:   '#e0e0e0',
    tagBg:    '#e8472b',
    tagTxt:   '#ffffff',
    sideHdr:  '#1a1a1a'
} -%}

{# Neowin category tabs — derived from content type identifier #}
{%- set cats = ['News','Software','Microsoft','Apple','Google','Linux','Security','Gaming','Hardware'] -%}

{# Icon map #}
{%- set ico = {
