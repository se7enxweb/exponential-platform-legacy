{# ════════════════════════════════════════════
   ④ SUBITEMS — card grid, only when present
   ════════════════════════════════════════════ #}
{% if children|length > 0 %}
{%- set subColors = ['#e53e3e','#dd6b20','#d69e2e','#38a169','#319795','#3182ce','#5a67d8','#805ad5','#d53f8c','#0bc5ea','#68d391','#f6e05e'] -%}
<div class="nw-sub">
    <div class="nw-sub-hdr">
        <div class="nw-sub-hdr-line"></div>
        <span class="nw-sub-title">Latest Content</span>
        <span class="nw-sub-count">{{ children|length }}</span>
        <div class="nw-filter-chips" id="nw-chips">
            <span class="nw-chip nw-chip-on" data-filter="all">All</span>
        </div>
    </div>

    <div class="nw-sub-grid" id="nw-sub-grid">
        {% for child in children %}
            {%- set cc  = child.getContent() -%}
            {%- set tid = cc.contentType.identifier -%}
            {%- set col = subColors[tid|length % 12] -%}
            <a href="{{ path('ez_urlalias', {locationId: child.id}) }}"
               class="nw-sub-card"
               data-type="{{ tid }}"
               tabindex="0"
               role="link">
                <div class="nw-sub-thumb" style="background:{{ col }}"></div>
                <div class="nw-sub-art">
                    <div class="nw-sub-art-bg"></div>
                    <div class="nw-sub-art-dots"></div>
                    <div class="nw-sub-art-ico">
                        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                    </div>
                </div>
                <div class="nw-sub-body">
                    <span class="nw-sub-cat" style="color:{{ col }}">
                        <svg width="6" height="6" viewBox="0 0 8 8" fill="{{ col }}"><circle cx="4" cy="4" r="4"/></svg>
                        {{ tid }}
                    </span>
                    <div class="nw-sub-name">{{ ez_content_name(cc) }}</div>
                    <div class="nw-sub-excerpt">
                        {% for fd in cc.contentType.fieldDefinitions %}
                            {% if fd.fieldTypeIdentifier in ['ezstring','eztext','ezrichtext','ezxmltext']
                                and fd.identifier not in ['name','short_name','title']
                                and not ez_field_is_empty(cc, fd.identifier) %}
                                {{ ez_render_field(cc, fd.identifier)|striptags|trim }}
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
                <div class="nw-sub-foot">
                    <span class="nw-sub-loc">loc:{{ child.id }}</span>
                    <span class="nw-sub-more">Read →</span>
                </div>
            </a>
        {% endfor %}
        <div class="nw-no-results" id="nw-no-results">No items match this filter.</div>
    </div>
</div>
{% endif %}

{# ════════════════════════════════════════════
   ⑤ FOOTER BAND
   ════════════════════════════════════════════ #}
<div class="nw-foot">
    <div class="nw-foot-inner">
        <span>{{ ct is not null ? ct.identifier : 'n/a' }} / Content {{ content.id }} / Location {{ location.id }}</span>
        <div class="nw-foot-links">
            <a href="/">Home</a>
            {% if location.depth > 1 %}<a href="{{ path('ez_urlalias', {locationId: location.parentLocationId}) }}">Parent</a>{% endif %}
            <a href="/admin/content/location/{{ location.id }}">Admin</a>
        </div>
    </div>
</div>

</div>{# /nw #}

{# jQuery already loaded by legacy pagelayout — just behaviour #}
<script>
(function($){
    'use strict';

    /* ── Build type filter chips from cards ── */
    var seen = {};
    $('#nw-sub-grid .nw-sub-card').each(function(){
        var t = $(this).data('type');
        if(!seen[t]){ seen[t]=0; }
        seen[t]++;
    });
    $.each(seen, function(t, n){
        $('#nw-chips').append('<span class="nw-chip" data-filter="'+t+'">'+t+' <small>('+n+')</small></span>');
    });

    /* ── Filter ── */
    $('#nw-chips').on('click','.nw-chip',function(){
        var f = $(this).data('filter');
        $('.nw-chip').removeClass('nw-chip-on');
        $(this).addClass('nw-chip-on');
        var visible = 0;
        if(f==='all'){
            $('#nw-sub-grid .nw-sub-card').removeClass('nw-hidden');
            visible = $('#nw-sub-grid .nw-sub-card').length;
        } else {
            $('#nw-sub-grid .nw-sub-card').each(function(){
                if($(this).data('type')===f){ $(this).removeClass('nw-hidden'); visible++; }
                else { $(this).addClass('nw-hidden'); }
            });
        }
        $('#nw-no-results').toggleClass('nw-show', visible===0);
    });

    /* ── ToC scroll-spy ── */
    $('#nw-toc').on('click','.nw-toc-item',function(){
        var $el = $('#'+$(this).data('target'));
        if($el.length) $('html,body').animate({scrollTop:$el.offset().top-55},280);
        $('.nw-toc-item').removeClass('nw-toc-active');
        $(this).addClass('nw-toc-active');
    });
    if('IntersectionObserver' in window){
        var obs = new IntersectionObserver(function(entries){
            entries.forEach(function(e){
                if(e.isIntersecting){
                    var id = e.target.id;
                    $('.nw-toc-item').removeClass('nw-toc-active');
                    $('.nw-toc-item[data-target="'+id+'"]').addClass('nw-toc-active');
                }
            });
        },{rootMargin:'-55px 0px -70% 0px'});
        $('.nw-sec').each(function(){ obs.observe(this); });
    }

    /* ── Schema toggle ── */
    $('#nw-schema-tog').on('click',function(){
        var $b = $('#nw-schema-body');
        $b.slideToggle(200,function(){
            var open = $b.is(':visible');
            $('#nw-schema-tog').html(
                '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="'+(open?'18 15 12 9 6 15':'6 9 12 15 18 9')+'"/></svg> '+(open?'Hide fields':'Show {{ ct is not null ? ct.fieldDefinitions|length : 0 }} fields')
            );
        });
    });

    /* ── Back to top ── */
    $('.nw-to-top').on('click',function(){ $('html,body').animate({scrollTop:0},300); });

    /* ── Subitem card entrance stagger ── */
    $('#nw-sub-grid .nw-sub-card').each(function(i){
        $(this).css({opacity:0,transform:'translateY(14px)'});
        setTimeout(function(el){
            $(el).animate({opacity:1},{duration:220,step:function(n){ $(this).css('transform','translateY('+(14*(1-n))+'px)'); }});
        }, i*40, this);
    });

    /* ── Card keyboard nav ── */
    $('#nw-sub-grid .nw-sub-card').on('keydown',function(e){
        if(e.key==='Enter'||e.key===' '){ e.preventDefault(); window.location.href=$(this).attr('href'); }
    });

    /* ── Exp-journey filter chips ── */
    $('#nw-exp-filters').on('click','.nw-exp-chip',function(){
        var f = $(this).data('expf');
        $('.nw-exp-chip').removeClass('nw-exp-chip-on');
        $(this).addClass('nw-exp-chip-on');
        if(f==='all'){
            $('#nw-exp-grid .nw-exp-card').removeClass('nw-exp-hidden');
        } else {
            $('#nw-exp-grid .nw-exp-card').each(function(){
                $(this).toggleClass('nw-exp-hidden', $(this).data('expcat') !== f);
            });
        }
    });

    /* ── Exp-journey card entrance stagger ── */
    $('#nw-exp-grid .nw-exp-card').each(function(i){
        $(this).css({opacity:0,transform:'translateY(18px)'});
        setTimeout(function(el){
            $(el).animate({opacity:1},{duration:260,step:function(n){ $(this).css('transform','translateY('+(18*(1-n))+'px)'); }});
        }, 80 + i*55, this);
    });

}(jQuery));
</script>
{% endblock %}
