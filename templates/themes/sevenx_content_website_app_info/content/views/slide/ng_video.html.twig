{# content \Netgen\IbexaSiteApi\API\Values\Content #}
{# location \Netgen\IbexaSiteApi\API\Values\Location #}

{% import 'themes/app/content/macros/content_fields.html.twig' as content_fields %}
{% import "themes/app/content/macros/video.html.twig" as video %}


{% if not content.fields.video_file.empty or not content.fields.video_identifier.empty %}
    <div class="view-type view-type-{{ view_type }} ng-video vl3">
        {{ video.poster_slide(content, use_lazy_load|default(false)) }}

        <div class="info">
            <h3 class="title">
                <a href={{ ez_path(location) }}>
                    {{ content_fields.title(content) }}
                </a>
            </h3>
        </div>
    </div>
{% endif %}
